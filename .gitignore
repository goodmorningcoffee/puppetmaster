*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project specific
output/*.csv
output/*.json
output/*.md
test_results/
*.log
.puppetmaster_config.json
discovery/.working_set.json

# SpiderFoot (auto-installed)
spiderfoot/

# SpiderFoot exports (add your own)
spiderfoot_exports/
spiderfoot_export/

# Dev containers (not for distribution)
.devcontainer/

# Internal docs (working notes)
docs/

# Domain lists with private data
domain_lists/*.txt
!domain_lists/.gitkeep

# Config with private data
config/*.json
!config/.gitkeep

# =============================================================================
# SECURITY - NEVER commit these files!
# =============================================================================
# SSH Private Keys (PEM, PPK, etc.)
*.pem
*.key
*.ppk
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa

# AWS Credentials
.aws/
*credentials*
*.aws_credentials

# Environment files with secrets
.env
.env.*
*.env

# Any file with "secret" in the name
*secret*
*SECRET*
